# Copy to backend/.env on the server and fill in. Never commit the real .env.

PROJECT_NAME="KRNL V3 Backend"
DEBUG=False
PORT=8000

# 32-byte urlsafe base64 Fernet key (reuse dev key or generate a new one)
ENCRYPTION_KEY=

# Supabase (reuse the existing project — migrations already applied there)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=

# Gemini
GEMINI_API_KEY=

# Redis — use the docker-compose service name as host, NOT localhost
REDIS_URL=redis://redis:6379/0

# CORS — lock to your Vercel frontend origin (JSON array, no trailing slash)
ALLOWED_ORIGINS=["https://your-app.vercel.app"]

# Web Push — generate a FRESH pair for prod:  python scripts/gen_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
